# ============================================================================
# EPISODE METADATA API - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in values for your environment
# Keep .env in .gitignore - NEVER commit actual secrets!
# ============================================================================

# APPLICATION CONFIG
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=Episode Metadata API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# DATABASE CONFIG
DATABASE_URL=postgresql://postgres:PASSWORD@episode-metadata-db-dev.xxxxx.us-east-1.rds.amazonaws.com:5432/postgres
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# AWS CONFIG
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=637423256673
AWS_ACCESS_KEY_ID=your_dev_access_key_here
AWS_SECRET_ACCESS_KEY=your_dev_secret_key_here

# S3 BUCKETS
S3_PRIMARY_BUCKET=episode-metadata-storage-dev
S3_THUMBNAIL_BUCKET=episode-metadata-thumbnails-dev
MAX_FILE_UPLOAD_SIZE_MB=500

# AI Video Editing - S3 Buckets
S3_RAW_FOOTAGE_BUCKET=episode-metadata-raw-footage-dev
S3_PROCESSED_VIDEOS_BUCKET=episode-metadata-processed-videos-dev
S3_TRAINING_DATA_BUCKET=episode-metadata-training-data-dev

# COGNITO AUTH
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1

# SQS QUEUE (THUMBNAIL GENERATION)
THUMBNAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/637423256673/episode-metadata-thumbnail-queue-dev

# REDIS (OPTIONAL - FOR RATE LIMITING)
REDIS_URL=redis://localhost:6379

# LOGGING
LOG_LEVEL=debug
CLOUDWATCH_LOG_GROUP=/ecs/episode-metadata-api-dev
CLOUDWATCH_LOG_STREAM=api-local

# FEATURES
ENABLE_THUMBNAIL_GENERATION=true
ENABLE_AUDIT_LOGGING=true

# AI Video Processing - SQS Queue
SQS_VIDEO_PROCESSING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/637423256673/episode-metadata-video-processing-dev.fifo
SQS_VIDEO_PROCESSING_DLQ_URL=https://sqs.us-east-1.amazonaws.com/637423256673/episode-metadata-video-processing-dlq-dev.fifo

# Claude AI - Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_DAILY_BUDGET_USD=50
# Redis-backed AI response cache (set to false to disable)
AI_CACHE_ENABLED=true

# Feed Scheduler — auto-generates social profiles every 4h (10+ API calls per cycle)
# Only enable when you want auto-generation running. Costs ~$30-50/cycle.
FEED_SCHEDULER_ENABLED=false

# ElevenLabs TTS (Amber voice) — get key from elevenlabs.io profile
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Amber Diagnostic Engine — Claude Code project directory (for execute-via-CLI)
CLAUDE_CODE_PROJECT_DIR=/absolute/path/to/your/project
# Level 2 auto-approve categories (set to true to unlock)
# AMBER_AUTO_APPROVE_DUPLICATE_BRAIN=true
# AMBER_AUTO_APPROVE_MEMORY_REMINDER=true

# Image Generation — Hybrid routing: DALL-E for quality (invitations, scenes), Flux for cost (overlays, icons)
# Both keys recommended. Set IMAGE_PROVIDER=dalle or flux to force one globally.
FAL_KEY=your-fal-ai-api-key
OPENAI_API_KEY=sk-your-openai-api-key
# Per-operation cap: max image API calls per batch (default: 3)
IMAGE_CALLS_PER_OPERATION=3
# Daily image budget in USD (default: 10). Blocks calls when exceeded.
AI_DAILY_IMAGE_BUDGET_USD=10

# remove.bg — primary provider for wardrobe background removal
# Used on wardrobe item upload and by scripts/backfill-wardrobe-bg.js
# https://www.remove.bg/api — pay-as-you-go ~$0.20/image
REMOVEBG_API_KEY=your_removebg_api_key

# Runway ML — video generation from still images (Gen-3 Turbo)
# Also used as a fallback for wardrobe background removal
RUNWAY_ML_API_KEY=your_runway_api_key

# Replicate API — depth estimation (DepthAnythingV2) for 3D effects in Scene Studio
REPLICATE_API_TOKEN=r8_your_replicate_api_token
# Optional: override SAM model used for segmentation/masking flows
# Default: meta/sam-2-video (interactive point-click segmentation on images)
# Note: meta/sam-2 is automatic-only and does NOT support point-click
# REPLICATE_SAM_MODEL=meta/sam-2-video
