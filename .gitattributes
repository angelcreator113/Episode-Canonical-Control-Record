# Auto-detect text files and normalize line endings
* text=auto

# Lock files — use ours strategy to avoid noisy merge conflicts
package-lock.json merge=ours

# Minified assets — treat as binary (no merge attempts)
*.min.js binary
*.min.css binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
